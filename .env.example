# WiFi Monitor Configuration
# Copy this file to .env and modify as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# Syslog Listener Configuration
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# Database and Logging
# DB_PATH=./wireless_stats.db
# LOG_PATH=./wireless_service.log

# Data Retention (in days, set to 0 to disable cleanup)
AUTH_EVENTS_RETENTION_DAYS=30
DAILY_STATS_RETENTION_DAYS=365

# Event Storage (set to true only if you need raw event audit trail)
# Recommended: false (more efficient, stores only unique users per day)
STORE_AUTH_EVENTS=false

# SSID Normalization (maps HP MSM controller interface codes to friendly names)
# Confirmed from controller CSV export (2026-03-03)
SSID_V1_NAME=DCPL-STAFF
SSID_V2_NAME=DCPL-PATRON
SSID_V3_NAME=DCPL-OPS
